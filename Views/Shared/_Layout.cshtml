@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AXCAN</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/estilo.css">
    <link rel="stylesheet" href="~/css/carrousel.css">
    
    <style>
        /* Estilos de Karla integrados */
        .card-negocio { transition: transform 0.3s ease; border-radius: 15px !important; }
        .card-negocio:hover { transform: translateY(-10px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .banner-card { height: 160px; object-fit: cover; }
        .logo-navbar { max-height: 40px; }
        .navbar { background-color: white !important; }
    </style>
</head>
<body class="bg-white d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-light sticky-top border-bottom">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <img src="~/imagenesaxcan/logo_axcan.png" alt="Logo AXCAN" class="logo-navbar">
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="AcercaDe">Acerca de Koi Labs</a>
                    </li>
                    
                    @if (Context.Session.GetInt32("UsuarioId") != null)
                    {
                        <li class="nav-item ms-lg-2 my-2 my-lg-0">
                            <a class="btn btn-warning text-dark px-3 rounded-pill fw-bold shadow-sm" asp-controller="Cita" asp-action="MisCitas">
                                <i class="bi bi-calendar-check"></i> Mis Citas
                            </a>
                        </li>
                    }

                    @if (Context.Session.GetString("UsuarioRol") == "empleado" || ViewBag.EsStaff == true)
                    {
                        <li class="nav-item ms-lg-2 my-2 my-lg-0">
                            <a asp-action="Secretario" class="btn btn-info text-dark rounded-pill px-4 shadow-sm fw-bold">
                                <i class="bi bi-person-badge"></i> Panel de Trabajo
                            </a>
                        </li>
                    }
                </ul>
                
                <div class="d-flex align-items-center gap-3">
                    @* LÓGICA DE USUARIO LOGUEADO *@
                    @if (Context.Session.GetString("UsuarioNombre") != null)
                    {
                        <div class="dropdown">
                            <button class="btn btn-outline-dark dropdown-toggle rounded-pill" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @Context.Session.GetString("UsuarioNombre")
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li><a class="dropdown-item" asp-action="ConfiguracionDeCuenta">Configuración</a></li>
                                @if (Context.Session.GetString("UsuarioRol") == "administrador")
                                {
                                    <li><a class="dropdown-item text-primary fw-bold" asp-action="Admin">Mi Dashboard</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" asp-action="Logout">Cerrar Sesión</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-action="login" class="nav-link fw-bold">Entrar</a>
                    }

                    @* BOTÓN DE REGISTRO DE NEGOCIO *@
                    @if (Context.Session.GetString("UsuarioRol") != "administrador")
                    {
                        <a asp-controller="Home" asp-action="registronegocio" class="btn btn-primary rounded-pill px-4 fw-bold">
                            Registra tu negocio
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-dark text-center py-4 mt-auto">
        <div class="container">
            <p class="small mb-0" style="color: var(--gold-axcan);">
                © @DateTime.Now.Year AXCAN · Todos los derechos reservados · Koi Labs
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Axcan</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/axcan.styles.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    [cite_start]<i class="bi bi-geo-alt-fill text-primary"></i> AXCAN [cite: 158]
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    [cite_start]<span class="navbar-toggler-icon"></span> [cite: 159]
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            [cite_start]<a class="nav-link text-white" asp-controller="Home" asp-action="Index">Inicio</a> [cite: 160]
                        </li>
                        <li class="nav-item">
                            [cite_start]<a class="nav-link text-white" asp-controller="Home" asp-action="acercade">Acerca de</a> [cite: 161]
                        </li>
                        
                        @* --- LÓGICA DE ROLES: ACCESO DIFERENCIADO --- *@
                        @if (Context.Session.GetString("UsuarioRol") == "administrador")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-info fw-bold" asp-controller="Home" asp-action="Admin">
                                   <i class="bi bi-speedometer2"></i> Dashboard Admin
                                [cite_start]</a> [cite: 172]
                            </li>
                        }
                        else if (Context.Session.GetString("UsuarioRol") == "usuario")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold" asp-controller="Home" asp-action="registronegocio">
                                   <i class="bi bi-plus-circle"></i> Registrar mi Empresa
                                [cite_start]</a> [cite: 163, 172]
                            </li>
                        }
                    </ul>

                    @* --- MENÚ DE USUARIO / PERFIL --- *@
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("UsuarioNombre") != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                   [cite_start]<i class="bi bi-person-circle"></i> @Context.Session.GetString("UsuarioNombre") [cite: 166]
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    [cite_start]<li><a class="dropdown-item" asp-controller="Home" asp-action="ConfiguracionCuenta"><i class="bi bi-gear"></i> Configuración</a></li> [cite: 19, 167]
                                    @if (Context.Session.GetString("UsuarioRol") == "administrador")
                                    {
                                        <li><a class="dropdown-item text-primary" asp-controller="Home" asp-action="Admin"><i class="bi bi-layout-text-sidebar-reverse"></i> Ir al Panel</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    [cite_start]<li><a class="dropdown-item text-danger" asp-controller="Home" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Salir</a></li> [cite: 168]
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                [cite_start]<a class="nav-link text-white" asp-controller="Home" asp-action="login">Entrar</a> [cite: 170]
                            </li>
                            <li class="nav-item">
                                [cite_start]<a class="btn btn-primary btn-sm mt-1 ms-lg-2" asp-controller="Home" asp-action="registro">Crear Cuenta</a> [cite: 171]
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            [cite_start]@RenderBody() [cite: 173]
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-auto py-3">
        <div class="container text-center">
            &copy; [cite_start]2026 - <span class="fw-bold">AXCAN</span> - <a asp-controller="Home" asp-action="Index">Koi Labs</a> [cite: 174]
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
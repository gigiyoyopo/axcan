                                <div><button class="btn btn-sm btn-light border"> < </button> <button class="btn btn-sm btn-light border"> > </button></div>
                            </div>
                            <table class="table table-bordered text-center">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Lun</th><th>Mar</th><th>Mié</th><th>Jue</th><th>Vie</th><th>Sáb</th><th>Dom</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @* Generación manual de días *@
                                    <tr>
                                        <td></td><td></td><td></td><td>1</td><td>2</td><td>3</td><td>4</td>
                                    </tr>
                                    @* ... resto de la cuadrícula de Axel ... *@
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="semanal">
                        <div class="calendario-semanal-timeline">
                            <div class="row g-0 border-top">
                                <div class="col-2 border-end py-3 text-center bg-light fw-bold">Hora</div>
                                <div class="col border-end py-3 text-center fw-bold">Lunes 02</div>
                                <div class="col border-end py-3 text-center fw-bold">Martes 03</div>
                                @* ... Columnas de Axel ... *@
                            </div>
                            <div class="row g-0 border-top">
                                <div class="col-2 border-end py-2 text-center small text-muted">09:00 AM</div>
                                <div class="col border-end bg-primary-subtle p-1"><small>Cita: Juan</small></div>
                                <div class="col border-end"></div>
                                @* ... Filas de tiempo de Axel ... *@
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var lat = @Model.ubicacion_lat;
        var lng = @Model.ubicacion_lng;
        var map = L.map('mapaAdmin').setView([lat, lng], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        var marker = L.marker([lat, lng], { draggable: true }).addTo(map);

        marker.on('dragend', function (e) {
            document.getElementById('lat').value = e.target.getLatLng().lat;
            document.getElementById('lng').value = e.target.getLatLng().lng;
        });
    </script>
}

@model axcan.Models.Empresa
@{ Layout = "_Layout"; }

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 p-4 rounded-4">
                <h5 class="fw-bold mb-3">Personalizar Card</h5>
                <form asp-action="EditarNegocio" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="id_empresa" />
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Nombre del Negocio</label>
                        <input type="text" asp-for="nombre_empresa" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Mover Ubicación (GPS)</label>
                        <div id="mapaAdmin" style="height: 200px; border-radius: 10px;" class="border"></div>
                        <input type="hidden" id="lat" asp-for="ubicacion_lat">
                        <input type="hidden" id="lng" asp-for="ubicacion_lng">
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Logo Nuevo</label>
                        <input type="file" name="logoArchivo" class="form-control form-control-sm">
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold">Guardar Cambios</button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 p-4 rounded-4">
                <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active rounded-pill" data-bs-toggle="pill" data-bs-target="#mensual">Mensual</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link rounded-pill" data-bs-toggle="pill" data-bs-target="#semanal">Semanal</button>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="mensual">
                        <div class="calendario-mensual-container">
                            @* Aquí va la lógica de celdas que Axel hizo a mano *@
                            <div class="d-flex justify-content-between align-items-center mb-3">

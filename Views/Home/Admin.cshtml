@model axcan.Models.Empresa
@{
    Layout = null;
    string rolActual = ViewBag.RolLocal as string ?? "administrador";
    var listaCitas = ViewBag.Citas as List<axcan.Models.Cita>;
}
<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AXCAN | Panel Premium</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root { 
            --sidebar-width: 260px; 
            --gold-axcan: #D4AF37; 
            --dark-axcan: #1a1a1a;
            --gray-axcan: #2d2d2d;
        }
        body { background-color: #0f0f0f; color: #fff; transition: all 0.3s ease; font-family: 'Segoe UI', sans-serif; }
        
        .sidebar { width: var(--sidebar-width); height: 100vh; position: fixed; top: 0; left: 0; z-index: 1000; background: var(--dark-axcan); border-right: 1px solid #333; overflow-y: auto;}
        .main-content { margin-left: var(--sidebar-width); padding: 30px; }
        .nav-link { color: #888; margin: 8px 15px; border-radius: 8px; padding: 12px; transition: 0.2s; }
        .nav-link:hover, .nav-link.active { background: rgba(212, 175, 55, 0.1); color: var(--gold-axcan) !important; font-weight: bold; border-left: 3px solid var(--gold-axcan); }

        .card-custom { background-color: var(--gray-axcan); border: 1px solid #333; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .axcan-input { background-color: #111; border: 1px solid #444; color: white; border-radius: 8px; padding: 10px; }
        .btn-gold { background-color: var(--gold-axcan); color: #000; font-weight: bold; border: none; border-radius: 8px; transition: 0.3s; }
        .btn-gold:hover { background-color: #bfa030; transform: translateY(-2px); }

        .admin-section { display: none; }
        .admin-section.active { display: block; animation: fadeIn 0.4s; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .phone-mockup { border: 10px solid #333; border-radius: 40px; height: 780px; position: sticky; top: 20px; background: #000; overflow: hidden; }
        
        .logo-sidebar { width: 80px; height: 80px; object-fit: cover; border: 2px solid var(--gold-axcan); border-radius: 50%; margin-bottom: 10px; }
    </style>
</head>
<body>

    <nav class="sidebar shadow">
        <div class="p-4 text-center border-bottom border-secondary">
            @if(!string.IsNullOrEmpty(Model.logotipo_url)) {
                <img src="@Model.logotipo_url" alt="Logo" class="logo-sidebar shadow" />
            }
            <h3 class="fw-bold mb-1" style="color: var(--gold-axcan); letter-spacing: 2px;">AXCAN</h3>
            <span class="badge bg-dark border border-warning text-warning rounded-pill">@rolActual.ToUpper()</span>
        </div>
        
        <div class="nav flex-column mt-4">
            @if(rolActual == "administrador") {
                <a href="#stats" class="nav-link active"><i class="bi bi-graph-up-arrow me-2"></i> Dashboard</a>
                <a href="#personal" class="nav-link"><i class="bi bi-people me-2"></i> Personal</a>
                <a href="#servicios" class="nav-link"><i class="bi bi-scissors me-2"></i> Servicios</a>
                <a href="#horarios" class="nav-link"><i class="bi bi-clock me-2"></i> Horarios</a>
                <a href="#configuracion" class="nav-link"><i class="bi bi-palette me-2"></i> Personalizar</a>
            } else {
                <a href="#calendario-secretario" class="nav-link active"><i class="bi bi-calendar-month me-2"></i> Gestión de Citas</a>
            }
            <hr class="text-secondary mx-3 my-4">
            <a asp-action="Index" asp-controller="Home" class="nav-link text-info"><i class="bi bi-house me-2"></i> Ir al Buscador</a>
            <a asp-action="Logout" asp-controller="Home" class="nav-link text-danger"><i class="bi bi-box-arrow-left me-2"></i> Cerrar Sesión</a>
        </div>
    </nav>

    <main class="main-content">
        <header class="mb-5">
            <h4 class="fw-bold text-white">Panel de Control <span style="color: var(--gold-axcan);">@Model.nombre_empresa</span></h4>
        </header>

        @if(rolActual == "administrador") {
            <div class="admin-section active" id="stats">
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="card card-custom p-4 text-center mb-3">
                            <h6 class="text-muted fw-bold small">CITAS TOTALES</h6>
                            <h1 class="fw-bold" style="color: var(--gold-axcan);">@(listaCitas?.Count ?? 0)</h1>
                        </div>
                        <div class="card card-custom p-4 text-center">
                            <h5 class="fw-bold small mb-3">Filtros Rápidos</h5>
                            <button class="btn btn-primary btn-sm w-100 mb-2" id="btn-grafica-citas">Ver Citas Totales</button>
                            <button class="btn btn-outline-danger btn-sm w-100 mb-2" id="btn-grafica-cancelaciones">Ver Cancelaciones</button>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="card card-custom p-4" style="min-height: 400px;">
                            <canvas id="grafica-principal"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-section" id="personal">
                <div class="card card-custom p-5">
                    <div class="d-flex justify-content-between mb-4">
                        <h4 class="fw-bold" style="color: var(--gold-axcan);">Equipo de Trabajo</h4>
                        <button class="btn btn-gold" data-bs-toggle="modal" data-bs-target="#modalAddEquipo">+ Vincular Staff</button>
                    </div>
                    <table class="table table-dark table-hover align-middle">
                        <tbody>
                            @if(ViewBag.Personal != null) {
                                foreach(var p in ViewBag.Personal) {
                                    <tr>
                                        <td><strong>@p.nombre</strong><br><small class="text-muted">@@@p.username</small></td>
                                        <td><span class="badge bg-secondary border border-warning text-warning">@p.subrol.ToUpper()</span></td>
                                        <td class="text-end"><button class="btn btn-sm btn-outline-danger">Remover</button></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="admin-section" id="servicios">
                <div class="card card-custom p-5">
                    <div class="d-flex justify-content-between mb-4">
                        <h4 class="fw-bold" style="color: var(--gold-axcan);">Catálogo de Servicios</h4>
                        <button class="btn btn-gold" data-bs-toggle="modal" data-bs-target="#modalAddServicio">+ Nuevo Servicio</button>
                    </div>
                    <div class="list-group">
                        @if(ViewBag.Servicios != null) {
                            foreach(var s in ViewBag.Servicios) {
                                <div class="list-group-item bg-transparent text-white border-secondary d-flex justify-content-between align-items-center mb-2 rounded">
                                    <div>
                                        <strong>@s.nombre_servicio</strong> <br>
                                        <small class="text-muted"><i class="bi bi-clock"></i> @s.duracion_minutos min</small>
                                    </div>
                                    <div class="text-end">
                                        <span class="fw-bold text-warning fs-5 d-block">$@s.precio</span>
                                        <button class="btn btn-sm btn-outline-info mt-1" data-bs-toggle="modal" data-bs-target="#modalEditServicio_@s.id_servicio">
                                            <i class="bi bi-pencil"></i> Editar
                                        </button>
                                    </div>
                                </div>

                                <div class="modal fade" id="modalEditServicio_@s.id_servicio" tabindex="-1">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content bg-dark border-info">
                                            <form asp-controller="Admin" asp-action="EditarServicio" method="post">
                                                <div class="modal-body p-4">
                                                    <h5 class="text-info mb-3">Editar Servicio</h5>
                                                    <input type="hidden" name="id_servicio" value="@s.id_servicio" />
                                                    <input type="hidden" name="id_empresa" value="@Model.id_empresa" />
                                                    
                                                    <label class="small text-muted">Nombre del Servicio</label>
                                                    <input type="text" name="nombre_servicio" class="form-control axcan-input mb-2" value="@s.nombre_servicio" required>
                                                    
                                                    <label class="small text-muted">Precio</label>
                                                    <input type="number" step="0.01" name="precio" class="form-control axcan-input mb-2" value="@s.precio" required>
                                                    
                                                    <label class="small text-muted">Duración (minutos)</label>
                                                    <input type="number" name="duracion_minutos" class="form-control axcan-input mb-3" value="@s.duracion_minutos" required>
                                                    
                                                    <button type="submit" class="btn btn-info w-100 fw-bold">Actualizar Cambios</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="admin-section" id="horarios">
                <div class="card card-custom p-5">
                    <h4 class="fw-bold mb-4" style="color: var(--gold-axcan);"><i class="bi bi-clock-history me-2"></i> Configuración de Horarios</h4>
                    <p class="text-muted small mb-4">Define las horas de apertura, cierre y los días de descanso.</p>
                    <form asp-controller="Home" asp-action="GuardarHorarios" method="post">
                        <input type="hidden" name="id_empresa" value="@Model.id_empresa" />
                        <div class="table-responsive">
                            <table class="table table-dark table-borderless align-middle">
                                <thead>
                                    <tr class="text-muted small border-bottom border-secondary">
                                        <th>Día</th>
                                        <th>Apertura</th>
                                        <th>Cierre</th>
                                        <th class="text-center">Descanso</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ 
                                        string[] dias = { "Domingo", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado" }; 
                                        var horariosActuales = ViewBag.Horarios as List<axcan.Models.HorarioNegocio>;
                                    }
                                    @for (int i = 0; i < 7; i++) {
                                        var hAct = horariosActuales?.FirstOrDefault(h => h.dia_semana == i);
                                        <tr>
                                            <td class="fw-bold text-warning">@dias[i]</td>
                                            <td><input type="time" name="apertura_@i" class="form-control axcan-input" value="@(hAct != null ? hAct.hora_apertura.ToString(@"hh\:mm") : "09:00")"></td>
                                            <td><input type="time" name="cierre_@i" class="form-control axcan-input" value="@(hAct != null ? hAct.hora_cierre.ToString(@"hh\:mm") : "18:00")"></td>
                                            <td class="text-center"><input class="form-check-input" type="checkbox" name="descanso_@i" @(hAct != null && hAct.es_descanso ? "checked" : "")></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-end mt-4"><button type="submit" class="btn btn-gold px-5 py-2 shadow"><i class="bi bi-save me-2"></i> Guardar</button></div>
                    </form>
                </div>
            </div>

            <div class="admin-section" id="configuracion">
                <div class="row">
                    <div class="col-lg-7 mb-4">
                        <div class="card card-custom p-4">
                            <h5 class="fw-bold mb-4" style="color: var(--gold-axcan);"><i class="bi bi-magic"></i> Editor en Tiempo Real</h5>
                            <form asp-controller="Home" asp-action="EditarNegocio" method="post" enctype="multipart/form-data">
                                <input type="hidden" asp-for="id_empresa" />
                                
                                <div class="mb-3">
                                    <label class="text-muted small fw-bold">Nombre del Negocio</label>
                                    <input type="text" asp-for="nombre_empresa" id="live-nombre" class="form-control axcan-input">
                                </div>
                                <div class="mb-3">
                                    <label class="text-muted small fw-bold">Color de Marca</label>
                                    <input type="color" asp-for="color_tema" id="live-color" class="form-control axcan-input" style="height: 50px;">
                                </div>
                                <div class="mb-3">
                                    <label class="text-muted small fw-bold">Descripción</label>
                                    <textarea asp-for="descripcion" id="live-desc" class="form-control axcan-input" rows="3"></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="text-muted small fw-bold">Banner (Imagen de fondo)</label>
                                    <input type="file" name="bannerArchivo" class="form-control axcan-input">
                                </div>
                                
                                <hr class="border-secondary my-4">
                                <h6 class="text-warning mb-3"><i class="bi bi-share"></i> Redes Sociales</h6>
                                
                                <div class="mb-3">
                                    <label class="text-muted small fw-bold"><i class="bi bi-facebook text-primary"></i> Link de Facebook</label>
                                    <input type="url" name="url_facebook" asp-for="url_facebook" class="form-control axcan-input" placeholder="https://facebook.com/tu-pagina">
                                </div>
                                <div class="mb-3">
                                    <label class="text-muted small fw-bold"><i class="bi bi-instagram text-danger"></i> Link de Instagram</label>
                                    <input type="url" name="url_instagram" asp-for="url_instagram" class="form-control axcan-input" placeholder="https://instagram.com/tu_perfil">
                                </div>

                                <div class="mb-4 mt-4">
                                    <label class="text-muted small fw-bold">Plantilla Base</label>
                                    <select asp-for="id_plantilla" id="live-plantilla" class="form-select axcan-input">
                                        <option value="1">Plantilla 1 (Reserva)</option>
                                        <option value="2">Plantilla 2 (Informativa)</option>
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-gold w-100 py-3 shadow">GUARDAR DISEÑO</button>
                            </form>
                        </div>
                    </div>
                    
                    <div class="col-lg-5">
                        <div class="phone-mockup shadow-lg">
                            <div class="bg-success text-white text-center py-1 small fw-bold">LIVE PREVIEW</div>
                            <iframe id="iframeDemo" src="/reservar/@Model.nombre_empresa.Replace(" ", "-").ToLower()" style="width:100%; height:100%; border:none; background:#fff;"></iframe>
                        </div>
                    </div>
                </div>
            </div>
        }
    </main>

    <div class="modal fade" id="modalAddServicio" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-warning">
                <form asp-controller="Admin" asp-action="CrearServicio" method="post">
                    <div class="modal-body p-4">
                        <h5 class="text-warning mb-3">Nuevo Servicio</h5>
                        <input type="hidden" name="id_empresa" value="@Model.id_empresa" />
                        <input type="text" name="nombre_servicio" class="form-control axcan-input mb-2" placeholder="Nombre del Servicio" required>
                        <input type="number" step="0.01" name="precio" class="form-control axcan-input mb-2" placeholder="Precio $" required>
                        <input type="number" name="duracion_minutos" class="form-control axcan-input mb-3" placeholder="Duración (minutos)" required>
                        <button type="submit" class="btn btn-gold w-100">Guardar Servicio</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalAddEquipo" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-warning">
                <form asp-controller="Home" asp-action="AgregarPersonal" method="post">
                    <div class="modal-body p-4">
                        <h5 class="text-warning mb-3">Vincular Usuario</h5>
                        <input type="hidden" name="idEmpresa" value="@Model.id_empresa" />
                        <label class="small fw-bold text-muted">Username de Axcan</label>
                        <input type="text" name="usernameBusqueda" class="form-control axcan-input mb-3" placeholder="Ej: karla_admin" required>
                        <label class="small fw-bold text-muted">Asignar Rol</label>
                        <select name="subrol" class="form-select axcan-input mb-4">
                            <option value="prestador">Prestador (Especialista)</option>
                            <option value="secretario">Secretario (Solo Agenda)</option>
                        </select>
                        <button type="submit" class="btn btn-gold w-100">Vincular al Equipo</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>

    <script>
        document.querySelectorAll('.nav-link[href^="#"]').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
                this.classList.add('active');
                document.querySelectorAll('.admin-section').forEach(sec => sec.classList.remove('active'));
                document.getElementById(this.getAttribute('href').substring(1)).classList.add('active');
            });
        });

        let miGrafica;
        document.addEventListener("DOMContentLoaded", function() {
            let ctx = document.getElementById('grafica-principal').getContext('2d');
            miGrafica = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ["Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom"],
                    datasets: [{
                        label: 'Citas',
                        backgroundColor: "#D4AF37",
                        data: [0, 0, 0, 0, 0, 0, 0] 
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });

            fetch(`/Home/GetDatosGraficas?idEmpresa=@Model.id_empresa`)
                .then(r => r.json())
                .then(data => {
                    if(data.citasPorDia) {
                        miGrafica.data.datasets[0].data = data.citasPorDia;
                        miGrafica.update();
                    }
                }).catch(e => console.log("Error cargando gráfica:", e));

            document.getElementById('btn-grafica-cancelaciones').onclick = () => {
                miGrafica.data.datasets[0].data = [1, 0, 2, 0, 1, 3, 1]; 
                miGrafica.data.datasets[0].backgroundColor = "#dc3545";
                miGrafica.data.datasets[0].label = 'Cancelaciones';
                miGrafica.update();
            };

            document.getElementById('btn-grafica-citas').onclick = () => {
                fetch(`/Home/GetDatosGraficas?idEmpresa=@Model.id_empresa`)
                    .then(r => r.json())
                    .then(data => {
                        miGrafica.data.datasets[0].data = data.citasPorDia || [12, 19, 3, 5, 2, 3, 10];
                        miGrafica.data.datasets[0].backgroundColor = "#D4AF37";
                        miGrafica.data.datasets[0].label = 'Citas';
                        miGrafica.update();
                    });
            };

            const iframe = document.getElementById('iframeDemo');
            
            document.getElementById('live-nombre').addEventListener('input', (e) => {
                const h1 = iframe.contentWindow.document.querySelector('h1');
                if(h1) h1.innerText = e.target.value;
            });

            document.getElementById('live-color').addEventListener('input', (e) => {
                const root = iframe.contentWindow.document.documentElement;
                root.style.setProperty('--brand-color', e.target.value);
            });

            document.getElementById('live-desc').addEventListener('input', (e) => {
                const desc = iframe.contentWindow.document.querySelector('.text-muted');
                if(desc) desc.innerText = e.target.value;
            });

            document.getElementById('live-plantilla').addEventListener('change', () => {
                iframe.src = iframe.src; 
            });
        });
    </script>
</body>
</html>
@{ Layout = null; }
<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AXCAN | Panel de Administración</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root { --sidebar-width: 260px; --gold-axcan: #D4AF37; }
        body { background-color: var(--bs-body-bg); transition: all 0.3s ease; }
        
        /* Sidebar Design */
        .sidebar { 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            top: 0; left: 0; 
            z-index: 1000;
            background: #111;
            transition: all 0.3s;
        }
        
        .main-content { margin-left: var(--sidebar-width); padding: 25px; transition: all 0.3s; }
        
        .nav-link { color: #aaa; margin: 8px 15px; border-radius: 10px; padding: 12px; }
        .nav-link:hover, .nav-link.active { background: var(--gold-axcan); color: #000 !important; font-weight: bold; }

        /* Mobile Adjustments */
        @@media (max-width: 992px) {
            .sidebar { left: -100%; }
            .sidebar.active { left: 0; }
            .main-content { margin-left: 0; }
        }

        .card-custom { border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: 0.3s; }
        .card-custom:hover { transform: translateY(-5px); }
        .logo-admin { max-width: 130px; filter: brightness(0) invert(1); }
        
        /* Dark/Light Switch */
        .theme-toggler { cursor: pointer; font-size: 1.5rem; color: var(--gold-axcan); }
    </style>
</head>
<body>


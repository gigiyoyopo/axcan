@{ Layout = null; }
<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AXCAN | Panel de Administración</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root { --sidebar-width: 260px; --gold-axcan: #D4AF37; }
        body { background-color: var(--bs-body-bg); transition: all 0.3s ease; }
        
        /* Sidebar Design */
        .sidebar { 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            top: 0; left: 0; 
            z-index: 1000;
            background: #111;
            transition: all 0.3s;
        }
        
        .main-content { margin-left: var(--sidebar-width); padding: 25px; transition: all 0.3s; }
        
        .nav-link { color: #aaa; margin: 8px 15px; border-radius: 10px; padding: 12px; }
        .nav-link:hover, .nav-link.active { background: var(--gold-axcan); color: #000 !important; font-weight: bold; }

        /* Mobile Adjustments */
        @@media (max-width: 992px) {
            .sidebar { left: -100%; }
            .sidebar.active { left: 0; }
            .main-content { margin-left: 0; }
        }

        .card-custom { border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: 0.3s; }
        .card-custom:hover { transform: translateY(-5px); }
        .logo-admin { max-width: 130px; filter: brightness(0) invert(1); }
        
        /* Dark/Light Switch */
        .theme-toggler { cursor: pointer; font-size: 1.5rem; color: var(--gold-axcan); }
    </style>
</head>
<body>

    <nav class="sidebar shadow" id="sidebar">
        <div class="p-4 text-center">
            <img src="/imagenesaxcan/logo_axcan.png" alt="AXCAN" class="logo-admin mb-3">
            <div class="text-white-50 small">MODO ADMINISTRADOR</div>
        </div>
        
        <div class="nav flex-column mt-3">
            <a href="#" class="nav-link active"><i class="bi bi-house-door me-2"></i> Dashboard</a>
            <a href="#" class="nav-link"><i class="bi bi-calendar3 me-2"></i> Gestionar Citas</a>
            <a href="#" class="nav-link"><i class="bi bi-people me-2"></i> Usuarios</a>
            <a href="#" class="nav-link"><i class="bi bi-person-vcard me-2"></i> Personal</a>
            <a href="#" class="nav-link"><i class="bi bi-scissors me-2"></i> Servicios</a>
            <a href="#" class="nav-link"><i class="bi bi-file-earmark-code me-2"></i> Plantillas</a>
            <hr class="text-secondary mx-3">
            <a href="/" class="nav-link text-info"><i class="bi bi-arrow-left-circle me-2"></i> Volver a Web</a>
        </div>
    </nav>

    <main class="main-content" id="main-content">
        
        <header class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <button class="btn btn-dark d-lg-none me-3" onclick="toggleMenu()"><i class="bi bi-list"></i></button>
                <h3 class="fw-bold mb-0">Panel Axcan</h3>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="theme-toggler" onclick="toggleTheme()">
                    <i id="theme-icon" class="bi bi-moon-stars-fill"></i>
                </div>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle rounded-pill" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle"></i> Katto Jara
                    </button>
                    <ul class="dropdown-menu border-0 shadow">
                        <li><a class="dropdown-item" href="#">Configuración</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="#">Cerrar Sesión</a></li>
                    </ul>
                </div>
            </div>
        </header>

        <div class="row g-4 mb-4">
            <div class="col-12 col-md-6 col-lg-3">
                <div class="card card-custom p-4 bg-white text-dark">
                    <div class="text-muted small fw-bold">CITAS TOTALES</div>
                    <h2 class="fw-bold">1,250</h2>
                    <span class="text-success small fw-bold">+12% este mes</span>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <div class="card card-custom p-4 bg-white text-dark">
                    <div class="text-muted small fw-bold">PERSONAL</div>
                    <h2 class="fw-bold">8</h2>
                    <span class="text-primary small fw-bold">Todos activos</span>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <div class="card card-custom p-4 bg-dark text-white">
                    <div class="text-muted small fw-bold">SERVICIOS</div>
                    <h2 class="fw-bold">15</h2>
                    <span class="text-warning small fw-bold text-uppercase">Configurados</span>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <div class="card card-custom p-4 bg-white text-dark">
                    <div class="text-muted small fw-bold">PROMEDIO CITAS</div>
                    <h2 class="fw-bold">4.8</h2>
                    <div class="text-warning"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i></div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            
            <div class="col-12 col-xl-8">
                <div class="card card-custom p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-trophy me-2 text-warning"></i>Usuarios con más Citas</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light text-uppercase small">
                                <tr>
                                    <th>Usuario</th>
                                    <th>Citas</th>
                                    <th>Estatus</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>Juan Pérez</strong><br><small class="text-muted">juan@@mail.com</small></td>
                                    <td><span class="badge bg-dark rounded-pill">32 agendadas</span></td>
                                    <td><span class="text-success">● VIP</span></td>
                                    <td><button class="btn btn-sm btn-outline-dark">Gestionar</button></td>
                                </tr>
                                <tr>
                                    <td><strong>María García</strong><br><small class="text-muted">maria@@mail.com</small></td>
                                    <td><span class="badge bg-dark rounded-pill">15 agendadas</span></td>
                                    <td><span class="text-primary">● Frecuente</span></td>
                                    <td><button class="btn btn-sm btn-outline-dark">Gestionar</button></td>
                                </tr>
                                <tr>
                                    <td><strong>Katto Jara</strong><br><small class="text-muted">admin@@axcan.com</small></td>
                                    <td><span class="badge bg-dark rounded-pill">12 agendadas</span></td>
                                    <td><span class="text-warning">● Premium</span></td>
                                    <td><button class="btn btn-sm btn-outline-dark">Gestionar</button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="card card-custom p-4 h-100">
                    <h5 class="fw-bold mb-3">Gestión de Servicios</h5>
                    <div class="list-group list-group-flush mb-3">
                        <div class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-4 mb-2">
                            <span>Corte Clásico</span>
                            <span class="fw-bold">$250</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-4 mb-2">
                            <span>Barba y Ritual</span>
                            <span class="fw-bold">$180</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-4 mb-2">
                            <span>Tinte Axcan</span>
                            <span class="fw-bold">$450</span>
                        </div>
                    </div>
                    <button class="btn btn-dark w-100 py-3 rounded-4 mt-auto">
                        <i class="bi bi-pencil-square me-2"></i>Editar Catálogo
                    </button>
                </div>
            </div>

        </div> </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle Sidebar en Celular
        function toggleMenu() {
            document.getElementById('sidebar').classList.toggle('active');
        }

        // Cambio de Color (Blanco / Negro)
        function toggleTheme() {
            const html = document.documentElement;
            const icon = document.getElementById('theme-icon');
            
            if (html.getAttribute('data-bs-theme') === 'light') {
                html.setAttribute('data-bs-theme', 'dark');
                icon.className = 'bi bi-sun-fill';
            } else {
                html.setAttribute('data-bs-theme', 'light');
                icon.className = 'bi bi-moon-stars-fill';
            }
        }
    </script>
</body>
</html>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro - AXCAN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/estilo.css">
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100 py-4" style="background-image: url('/imagenesaxcan/fondo_login_registro.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat; background-attachment: fixed; position: relative; z-index: 1;">


    <div class="container d-flex justify-content-center">
        <div class="card shadow-lg p-4 auth-card col-12 col-sm-8 col-md-6 col-lg-5">
            
            <div class="text-center mb-3 max-width-200 mx-auto">
                <div class="logo-container">
                    <span class="fw-bold text-primary">
                        <img src="~/imagenesaxcan/logo_axcan.png" alt="Logo AXCAN" class="logo-navbar">
                    </span>
                </div>
            </div>

            <h2 class="text-center fw-bold mb-4">Crear Cuenta</h2>

            <form id="registerForm" asp-controller="Home" asp-action="ProcesarRegistro" method="post">
                
                <div class="form-floating mb-3">
                    <input type="text" name="nombre" class="form-control" id="regNombre" placeholder="Nombre" required>
                    <label for="regNombre">Nombre</label>
                </div>

                <div class="form-floating mb-3">
                    <input type="text" name="apellido_paterno" class="form-control" id="regPat" placeholder="Ap. Paterno" required>
                    <label for="regPat">Apellido Paterno</label>
                </div>

                <div class="form-floating mb-3">
                    <input type="text" name="apellido_materno" class="form-control" id="regMat" placeholder="Ap. Materno" required>
                    <label for="regMat">Apellido Materno</label>
                </div>

                <div class="form-floating mb-3">
                    <input type="email" name="correo" class="form-control" id="regEmail" placeholder="correo@ejemplo.com" required>
                    <label for="regEmail">Correo Electrónico</label>
                </div>

                <div class="form-floating mb-3">
                    <input type="text" name="username" class="form-control" id="regUser" placeholder="Usuario" required>
                    <label for="regUser">Nombre de Usuario</label>
                </div>

                <div class="form-floating mb-3">
                    <input type="password" name="password" class="form-control" id="regPass" placeholder="Contraseña" required>
                    <label for="regPass">Contraseña</label>
                </div>

                <div class="form-floating mb-4">
                    <input type="password" class="form-control" id="regPassConfirm" placeholder="Confirmar Contraseña" required>
                    <label for="regPassConfirm">Confirmar Contraseña</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-3" ">
                    REGISTRARME
                </button>
            </form>
            <div class="d-flex align-items-center my-3">
                <hr class="flex-grow-1">
                <span class="mx-2 text-muted small">O REGÍSTRATE CON</span>
                <hr class="flex-grow-1">
            </div>

            <div id="g_id_onload"
                 data-client_id="1058925398660-ovi8nq4pj2a0qtn7kmelganfug5lu008.apps.googleusercontent.com"
                 data-context="signup"
                 data-ux_mode="popup"
                 data-callback="handleGoogleResponse"
                 data-auto_prompt="false">
            </div>

            <div class="d-flex justify-content-center">
                <div class="g_id_signin" data-width="100%" data-type="standard" data-shape="pill"></div>
            </div>

            <div class="text-center mt-3">
                <p class="small text-muted">¿Ya tienes cuenta? <a asp-controller="Home" asp-action="login" class="fw-bold">Inicia Sesión</a></p>
            </div>
        </div>
    </div>
    
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script src="~/js/alejandro.js"></script>
</body>
</html>
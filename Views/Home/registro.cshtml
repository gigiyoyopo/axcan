@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro - AXCAN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/estilo.css">
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100 py-4 fondo-auth">

    <div class="container d-flex justify-content-center">
        <div class="card shadow-lg p-4 auth-card col-12 col-sm-8 col-md-6 col-lg-5">
            
            <div class="text-center mb-3 max-width-200 mx-auto">
                <div class="logo-container">
                    <span class="fw-bold text-primary">
                        <img src="~/imagenesaxcan/logo_axcan.png"
                            alt="Logo AXCAN"
                            class="logo-navbar">
                    </span>
                </div>
            </div>

            <h2 class="text-center fw-bold mb-4">Crear Cuenta</h2>
<form id="registerForm" asp-controller="Home" asp-action="ProcesarRegistro" method="post">
    <div class="form-floating mb-3">
        <input type="text" name="nombre" class="form-control" id="regNombre" placeholder="Nombre" required>
        <label>Nombre</label>
    </div>

    <div class="form-floating mb-3">
        <input type="text" name="apellido_paterno" class="form-control" id="regPat" placeholder="Ap. Paterno" required>
        <label>Apellido Paterno</label>
    </div>

    <div class="form-floating mb-3">
        <input type="text" name="apellido_materno" class="form-control" id="regMat" placeholder="Ap. Materno" required>
        <label>Apellido Materno</label>
    </div>

    <div class="form-floating mb-3">
        <input type="email" name="correo" class="form-control" id="regEmail" placeholder="Correo" required>
        <label>Correo Electrónico</label>
    </div>

    </form>
            <div class="text-center mt-3">
                <p class="small text-muted">¿Ya tienes cuenta? <a asp-controller="Home" asp-action="login" class="fw-bold">Inicia Sesión</a></p>
            </div>
        </div>
    </div>
    
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script src="~/js/alejandro2.js"></script>
</body>
</html>
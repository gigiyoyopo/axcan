@using Microsoft.AspNetCore.Http
@model axcan.Models.Empresa
@{
    Layout = null;
    string colorTema = string.IsNullOrEmpty(Model.color_tema) ? "#111" : Model.color_tema;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>@Model.nombre_empresa | AXCAN Exclusive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root { --brand-color: @colorTema; }
        body { background-color: #fcfcfc; font-family: 'Poppins', sans-serif; color: #222; }
        
        .header-gallery { height: 55vh; position: relative; overflow: hidden; border-radius: 0 0 50px 50px; background: #000; }
        .hero-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 4px; width: 100%; height: 100%; }
        .hero-grid img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.6); transition: filter 0.3s; }
        .hero-grid img:hover { filter: brightness(0.9); }
        .hg-1 { grid-column: 1 / 2; grid-row: 1 / 3; }
        .hg-2 { grid-column: 2 / 4; grid-row: 1 / 2; }
        .hg-3 { grid-column: 2 / 3; grid-row: 2 / 3; }
        .hg-4 { grid-column: 3 / 4; grid-row: 2 / 3; }

        .floating-info { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: white; z-index: 10; width: 90%; background: rgba(0,0,0,0.3); padding: 40px; border-radius: 30px; backdrop-filter: blur(5px); }
        .service-card { background: white; border: 2px solid #f0f0f0; border-radius: 20px; padding: 20px; transition: 0.3s; cursor: pointer; text-align: center; }
        .service-card:hover { border-color: var(--brand-color); transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .service-card.active { border-color: var(--brand-color); background: rgba(0,0,0,0.02); }
        .service-card i { font-size: 2rem; color: var(--brand-color); }

        .booking-sidebar { position: sticky; top: 20px; border-radius: 35px; border: none; background: white; padding: 40px; box-shadow: 0 20px 50px rgba(0,0,0,0.1); }
        .section-title { font-weight: 800; text-transform: uppercase; letter-spacing: 3px; color: var(--brand-color); margin-bottom: 25px; font-size: 0.9rem; }
        .chip-hora { border: 1px solid #eee; padding: 12px 20px; border-radius: 15px; cursor: pointer; transition: 0.3s; background: #fff; font-weight: 500; }
        .chip-hora:hover { border-color: var(--brand-color); }
        .chip-hora.active { background-color: var(--brand-color); color: white; border-color: var(--brand-color); }
        .review-card { background: #fff; border-radius: 25px; padding: 25px; margin-bottom: 20px; border-bottom: 4px solid var(--brand-color); box-shadow: 0 5px 15px rgba(0,0,0,0.02); }
        .map-container { height: 400px; border-radius: 40px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
        .btn-reserve-final { background: var(--brand-color); color: white; border-radius: 50px; border: none; padding: 15px; font-weight: bold; width: 100%; transition: 0.3s; }
        .btn-reserve-final:hover { filter: brightness(1.2); transform: scale(1.02); }
        .star-rating i { cursor: pointer; transition: 0.2s; }
    </style>
</head>
<body>

    <a href="/" class="btn btn-light rounded-pill shadow" style="position: fixed; top: 20px; left: 20px; z-index: 1000; padding: 12px 25px; font-weight: 600;">
        <i class="bi bi-chevron-left"></i> Volver
    </a>

    <section class="header-gallery">
        <div class="hero-grid">
            @{
                var galeria = ViewBag.Galeria as IEnumerable<dynamic>;
                var imgs = new List<string>();
                if(galeria != null) { foreach(var f in galeria) { if(imgs.Count < 4) imgs.Add(f.url); } }
                while(imgs.Count < 4) { imgs.Add(Model.banner_url); }
            }
            <img src="@imgs[0]" class="hg-1">
            <img src="@imgs[1]" class="hg-2">
            <img src="@imgs[2]" class="hg-3">
            <img src="@imgs[3]" class="hg-4">
        </div>
        <div class="floating-info">
            <img src="@Model.logotipo_url" width="100" height="100" class="rounded-circle border border-4 border-white mb-4 shadow-lg" style="object-fit: cover;">
            <h1 class="display-2 fw-bold">@Model.nombre_empresa</h1>
            <p class="fs-4 fw-light text-uppercase tracking-widest">@Model.rubro</p>
        </div>
    </section>

    <div class="container mt-5 pt-4">
        <div class="row g-5">
            <div class="col-lg-7">

                <div class="d-flex align-items-center justify-content-start gap-4 mb-5">
                    <div class="p-3 bg-light rounded-circle text-center" style="width: 80px; height: 80px;">
                        <i class="bi bi-person-check fs-2" style="color: var(--brand-color);"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-0"><span class="counter-citas" data-target="@ViewBag.TotalCitas">0</span>+</h2>
                        <span class="text-muted text-uppercase tracking-widest small fw-bold">Clientes Atendidos</span>
                    </div>
                </div>

                <div class="mb-5">
                    <p class="section-title">Nuestra Esencia</p>
                    <h2 class="fw-bold mb-4">Experiencias diseñadas para ti.</h2>
                    <p class="text-muted fs-5 lh-lg" style="white-space: pre-line;">@Model.descripcion</p>
                    <div class="d-flex gap-4 mt-4">
                        @if (!string.IsNullOrEmpty(Model.url_facebook)) { <a href="@Model.url_facebook" target="_blank" class="fs-2 transition" style="color: var(--brand-color);"><i class="bi bi-facebook"></i></a> }
                        @if (!string.IsNullOrEmpty(Model.url_instagram)) { <a href="@Model.url_instagram" target="_blank" class="fs-2 transition" style="color: var(--brand-color);"><i class="bi bi-instagram"></i></a> }
                    </div>
                </div>

                <div class="mb-5">
                    <p class="section-title">Elige un Servicio</p>
                    <div class="row g-3">
                        @if(ViewBag.Servicios != null) {
                            foreach(var s in ViewBag.Servicios) {
                                <div class="col-md-6">
                                    <div class="service-card" onclick="selectService(this, '@s.nombre_servicio', '@s.precio')">
                                        <i class="bi bi-star"></i>
                                        <h5 class="fw-bold mt-3 mb-1">@s.nombre_servicio</h5>
                                        <p class="text-muted small mb-0">$@s.precio MXN</p>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <input type="hidden" id="p2-servicio-val">
                </div>

                <div class="mb-5">
                    <p class="section-title">Ubicación Premium</p>
                    <div id="mapaP2" class="map-container"></div>
                </div>

                <div class="mb-5">
                    <p class="section-title">Opiniones</p>

                    @if (Context.Session.GetInt32("UsuarioId") != null)
                    {
                        <div class="review-card bg-light border-0">
                            <h6 class="fw-bold mb-3">Cuéntanos tu experiencia</h6>
                            <div class="star-rating text-warning fs-3 mb-3" id="estrellas-p2">
                                <i class="bi bi-star-fill" data-val="1"></i>
                                <i class="bi bi-star-fill" data-val="2"></i>
                                <i class="bi bi-star-fill" data-val="3"></i>
                                <i class="bi bi-star-fill" data-val="4"></i>
                                <i class="bi bi-star-fill" data-val="5"></i>
                            </div>
                            <input type="hidden" id="calif-p2" value="5">
                            <textarea id="coment-p2" class="form-control mb-3 border-0 shadow-sm rounded-4 p-3" placeholder="Tu opinión ayuda a otros clientes..." rows="2"></textarea>
                            <button class="btn btn-dark rounded-pill px-5 fw-bold" onclick="enviarResenaP2()">Publicar Reseña</button>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light border rounded-pill text-center mb-4">
                            <i class="bi bi-info-circle me-2"></i> <a href="/Home/login" class="fw-bold" style="color: var(--brand-color);">Inicia sesión</a> para dejar tu opinión.
                        </div>
                    }

                    @if (ViewBag.Resenas != null) {
                        foreach (var r in ViewBag.Resenas) {
                            <div class="review-card">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(r.foto_url) ? "https://ui-avatars.com/api/?name="+r.nombre : r.foto_url)" width="45" class="rounded-circle me-3">
                                        <h6 class="fw-bold mb-0">@r.nombre</h6>
                                    </div>
                                    <span class="text-warning">
                                        @for(int i=0; i<r.calificacion; i++){ <i class="bi bi-star-fill"></i> }
                                    </span>
                                </div>
                                <p class="text-muted mb-0" style="font-style: italic;">"@r.comentario"</p>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="col-lg-5">
                <div class="booking-sidebar">
                    <h3 class="fw-bold text-center mb-4">Reservar</h3>
                    <div class="mb-4">
                        <label class="small fw-bold mb-2">Especialista</label>
                        <select id="p2-staff" class="form-select border-0 bg-light p-3 rounded-4">
                            @if(ViewBag.Personal != null) {
                                foreach(var p in ViewBag.Personal) { <option value="@p.nombre">@p.nombre</option> }
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="small fw-bold mb-2">Fecha</label>
                        <input type="date" id="p2-fecha" class="form-control border-0 bg-light p-3 rounded-4" min="@DateTime.Now.ToString("yyyy-MM-dd")">
                    </div>
                    <label class="small fw-bold mb-2">Horarios Disponibles</label>
                    <div id="p2-horas-cont" class="d-flex flex-wrap gap-2 mb-4">
                        <p class="text-muted small">Selecciona una fecha...</p>
                    </div>
                    <div class="bg-light p-4 rounded-4 mb-4">
                        <label class="small fw-bold mb-2 text-dark">Tus Datos</label>
                        <input type="text" id="p2-nombre-cliente" class="form-control border-0 mb-2 p-2" placeholder="Tu Nombre">
                        <input type="tel" id="p2-tel" class="form-control border-0 p-2" placeholder="Tu Teléfono (10 dígitos)">
                    </div>
                    <button onclick="agendarP2()" class="btn-reserve-final shadow-lg">CONFIRMAR CITA</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Animación del Contador de Citas
        const counter = document.querySelector('.counter-citas');
        const target = +counter.getAttribute('data-target');
        const updateCounter = () => {
            const c = +counter.innerText;
            const increment = target / 30; 
            if (c < target) {
                counter.innerText = Math.ceil(c + increment);
                setTimeout(updateCounter, 40);
            } else {
                counter.innerText = target;
            }
        };
        updateCounter();

        // Lógica de Estrellas para Reseñas
        const stars = document.querySelectorAll('#estrellas-p2 i');
        const califInput = document.getElementById('calif-p2');
        stars.forEach(star => {
            star.addEventListener('click', function() {
                let val = this.getAttribute('data-val');
                califInput.value = val;
                stars.forEach(s => {
                    if(s.getAttribute('data-val') <= val) {
                        s.classList.replace('bi-star', 'bi-star-fill');
                    } else {
                        s.classList.replace('bi-star-fill', 'bi-star');
                    }
                });
            });
        });
function enviarResenaP2() {
    let fd = new FormData();
    fd.append('id_empresa', '@Model.id_empresa');
    fd.append('calificacion', document.getElementById('calif-p2').value);
    fd.append('comentario', document.getElementById('coment-p2').value);

    fetch('/Home/GuardarResena', { method: 'POST', body: fd })
    .then(r => r.json())
    .then(d => {
        if(d.success) { 
            alert('¡Gracias por compartir tu experiencia!'); 
            location.reload(); 
        } else { 
            alert('Error de base de datos: ' + d.mensaje); 
        }
    })
    .catch(e => { alert("Error de conexión. Revisa la terminal negra de .NET."); });
}        // Lógica original del mapa y agendar...
        var lat = @(Model.ubicacion_lat != 0 ? Model.ubicacion_lat : 19.4326);
        var lng = @(Model.ubicacion_lng != 0 ? Model.ubicacion_lng : -99.1332);
        var map = L.map('mapaP2').setView([lat, lng], 16);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        L.marker([lat, lng]).addTo(map).bindPopup("<b>@Model.nombre_empresa</b>").openPopup();

        let servicioSeleccionado = "";
        function selectService(el, name, price) {
            document.querySelectorAll('.service-card').forEach(c => c.classList.remove('active'));
            el.classList.add('active');
            servicioSeleccionado = name;
        }

        let selHora = "";
        document.getElementById('p2-fecha').addEventListener('change', function() {
            const idEmp = '@Model.id_empresa';
            fetch(`/Home/GetHorariosDisponibles?idEmpresa=${idEmp}&fecha=${this.value}`)
            .then(r => r.json()).then(data => {
                let div = document.getElementById('p2-horas-cont');
                div.innerHTML = ''; 
                if(data.disponibles && data.disponibles.length > 0) {
                    data.disponibles.forEach(h => {
                        let btn = document.createElement('div');
                        btn.className = 'chip-hora';
                        btn.innerText = h;
                        btn.onclick = function() {
                            document.querySelectorAll('.chip-hora').forEach(c => c.classList.remove('active'));
                            this.classList.add('active');
                            selHora = h;
                        };
                        div.appendChild(btn);
                    });
                } else {
                    div.innerHTML = '<p class="text-danger small fw-bold">Sin citas disponibles</p>';
                }
            });
        });

        function agendarP2() {
            let tel = document.getElementById('p2-tel').value;
            let staff = document.getElementById('p2-staff').value;
            let fecha = document.getElementById('p2-fecha').value;
            if(!servicioSeleccionado || !fecha || !selHora || tel.length < 10) return alert("Completa todos los datos de la reserva.");

            let fd = new FormData();
            fd.append('id_empresa', '@Model.id_empresa');
            fd.append('fecha', fecha);
            fd.append('hora', selHora);
            fd.append('tipo_servicio', servicioSeleccionado);
            fd.append('quien_atiende', staff);

            fetch('/Home/AgendarCita', { method: 'POST', body: fd })
            .then(r => r.json()).then(d => {
                if(d.success) { alert("¡Cita agendada!"); window.location.href = '/Cita/MisCitas'; }
                else { alert("Error al agendar."); }
            });
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
@model axcan.Models.Empresa
@{
    Layout = null;
    string colorTema = string.IsNullOrEmpty(Model.color_tema) ? "#111" : Model.color_tema;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>@Model.nombre_empresa | AXCAN Exclusive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root { --brand-color: @colorTema; }
        body { background-color: #fcfcfc; font-family: 'Poppins', sans-serif; color: #222; }
        
        /* 1. Hero Refinado */
        .header-gallery { height: 55vh; position: relative; overflow: hidden; border-radius: 0 0 50px 50px; }
        .galeria-img-full { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.5); }
        
        .floating-info { 
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            text-align: center; color: white; z-index: 10; width: 90%;
        }

        /* 2. Tarjetas de Servicios Visuales */
        .service-card {
            background: white; border: 2px solid #f0f0f0; border-radius: 20px;
            padding: 20px; transition: 0.3s; cursor: pointer; text-align: center;
        }
        .service-card:hover { border-color: var(--brand-color); transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .service-card.active { border-color: var(--brand-color); background: rgba(0,0,0,0.02); }
        .service-card i { font-size: 2rem; color: var(--brand-color); }

        /* 3. Sidebar de Reserva Estilo Minimal */
        .booking-sidebar { 
            position: sticky; top: 20px; 
            border-radius: 35px; border: none; 
            background: white; padding: 40px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        }

        .section-title { 
            font-weight: 800; text-transform: uppercase; letter-spacing: 3px; 
            color: var(--brand-color); margin-bottom: 25px; font-size: 0.9rem;
        }

        .chip-hora { 
            border: 1px solid #eee; padding: 12px 20px; border-radius: 15px; 
            cursor: pointer; transition: 0.3s; background: #fff; font-weight: 500;
        }
        .chip-hora:hover { border-color: var(--brand-color); }
        .chip-hora.active { background-color: var(--brand-color); color: white; border-color: var(--brand-color); }

        .review-card {
            background: #fff; border-radius: 25px; padding: 25px; margin-bottom: 20px;
            border-bottom: 4px solid var(--brand-color); box-shadow: 0 5px 15px rgba(0,0,0,0.02);
        }
        
        .map-container { height: 400px; border-radius: 40px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
        .btn-reserve-final { background: var(--brand-color); color: white; border-radius: 50px; border: none; padding: 15px; font-weight: bold; width: 100%; transition: 0.3s; }
        .btn-reserve-final:hover { filter: brightness(1.2); transform: scale(1.02); }
    </style>
</head>
<body>

    <a href="/" class="btn btn-light rounded-pill shadow" style="position: fixed; top: 20px; left: 20px; z-index: 1000; padding: 12px 25px; font-weight: 600;">
        <i class="bi bi-chevron-left"></i> Volver
    </a>

    <section class="header-gallery">
        <div id="p2Carousel" class="carousel slide carousel-fade h-100" data-bs-ride="carousel">
            <div class="carousel-inner h-100">
                @if (ViewBag.Galeria != null && ((IEnumerable<dynamic>)ViewBag.Galeria).Any()) {
                    bool isFirst = true;
                    foreach (var img in ViewBag.Galeria) {
                        <div class="carousel-item h-100 @(isFirst ? "active" : "")">
                            <img src="@img.url" class="galeria-img-full">
                        </div>
                        isFirst = false;
                    }
                } else {
                    <div class="carousel-item active h-100">
                        <img src="@Model.banner_url" class="galeria-img-full">
                    </div>
                }
            </div>
        </div>
        <div class="floating-info">
            <img src="@Model.logotipo_url" width="100" height="100" class="rounded-circle border border-4 border-white mb-4 shadow-lg">
            <h1 class="display-2 fw-bold">@Model.nombre_empresa</h1>
            <p class="fs-4 fw-light text-uppercase tracking-widest">@Model.rubro</p>
        </div>
    </section>

    <div class="container mt-5 pt-4">
        <div class="row g-5">
            <div class="col-lg-7">
                <div class="mb-5">
                    <p class="section-title">Nuestra Esencia</p>
                    <h2 class="fw-bold mb-4">Experiencias diseñadas para ti.</h2>
                    <p class="text-muted fs-5 lh-lg">@Model.descripcion</p>
                </div>

                <div class="mb-5">
                    <p class="section-title">Elige un Servicio</p>
                    <div class="row g-3">
                        @foreach(var s in ViewBag.Servicios) {
                            <div class="col-md-6">
                                <div class="service-card" onclick="selectService(this, '@s.nombre_servicio', '@s.precio')">
                                    <i class="bi bi-star"></i>
                                    <h5 class="fw-bold mt-3 mb-1">@s.nombre_servicio</h5>
                                    <p class="text-muted small mb-0">$@s.precio MXN</p>
                                </div>
                            </div>
                        }
                    </div>
                    <input type="hidden" id="p2-servicio-val">
                </div>

                <div class="mb-5">
                    <p class="section-title">Ubicación Premium</p>
                    <div id="mapaP2" class="map-container"></div>
                </div>

                <div class="mb-5">
                    <p class="section-title">Opiniones</p>
                    @if (ViewBag.Resenas != null) {
                        foreach (var r in ViewBag.Resenas) {
                            <div class="review-card">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(r.foto_url) ? "https://ui-avatars.com/api/?name="+r.nombre : r.foto_url)" width="45" class="rounded-circle me-3">
                                        <h6 class="fw-bold mb-0">@r.nombre</h6>
                                    </div>
                                    <span class="text-warning">
                                        @for(int i=0; i<r.calificacion; i++){ <i class="bi bi-star-fill"></i> }
                                    </span>
                                </div>
                                <p class="text-muted mb-0 italic">"@r.comentario"</p>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="col-lg-5">
                <div class="booking-sidebar">
                    <h3 class="fw-bold text-center mb-4">Reservar</h3>
                    
                    <div class="mb-4">
                        <label class="small fw-bold mb-2">Especialista</label>
                        <select id="p2-staff" class="form-select border-0 bg-light p-3 rounded-4">
                            @foreach(var p in ViewBag.Personal) {
                                <option value="@p.nombre">@p.nombre</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="small fw-bold mb-2">Fecha</label>
                        <input type="date" id="p2-fecha" class="form-control border-0 bg-light p-3 rounded-4" min="@DateTime.Now.ToString("yyyy-MM-dd")">
                    </div>

                    <label class="small fw-bold mb-2">Horarios Disponibles</label>
                    <div id="p2-horas-cont" class="d-flex flex-wrap gap-2 mb-4">
                        <p class="text-muted small">Selecciona una fecha...</p>
                    </div>

                    <div class="bg-light p-4 rounded-4 mb-4">
                        <label class="small fw-bold mb-2 text-dark">Tus Datos</label>
                        <input type="text" id="p2-nombre-cliente" class="form-control border-0 mb-2 p-2" placeholder="Tu Nombre" value="@Context.Session.GetString("UsuarioNombre")">
                        <input type="tel" id="p2-tel" class="form-control border-0 p-2" placeholder="Tu Teléfono">
                    </div>

                    <button onclick="agendarP2()" class="btn-reserve-final shadow-lg">CONFIRMAR CITA</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    // 1. MAPA DINÁMICO
    var lat = @(Model.ubicacion_lat != 0 ? Model.ubicacion_lat : 19.4326);
    var lng = @(Model.ubicacion_lng != 0 ? Model.ubicacion_lng : -99.1332);
    var map = L.map('mapaP2').setView([lat, lng], 16);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    L.marker([lat, lng]).addTo(map).bindPopup("<b>@Model.nombre_empresa</b>").openPopup();

    // 2. SELECCIÓN DE SERVICIO (REPARADO)
    let servicioSeleccionado = "";
    function selectService(el, name, price) {
        // Quitar clase activa de todas las tarjetas
        document.querySelectorAll('.service-card').forEach(c => c.classList.remove('active'));
        // Poner clase activa a la que clickeaste
        el.classList.add('active');
        // Guardar el nombre del servicio
        servicioSeleccionado = name;
        // Opcional: mostrar alerta visual de selección
        console.log("Servicio elegido: " + name);
    }

    // 3. LÓGICA DE HORARIOS (REPARADO)
    let selHora = "";
    document.getElementById('p2-fecha').addEventListener('change', function() {
        const fechaVal = this.value;
        const idEmp = '@Model.id_empresa';
        
        if(!fechaVal) return;

        fetch(`/Home/GetHorariosDisponibles?idEmpresa=${idEmp}&fecha=${fechaVal}`)
        .then(r => {
            if (!r.ok) throw new Error("Error en servidor");
            return r.json();
        })
        .then(data => {
            let div = document.getElementById('p2-horas-cont');
            div.innerHTML = ''; // Limpiar mensaje anterior
            
            if(data.disponibles && data.disponibles.length > 0) {
                data.disponibles.forEach(h => {
                    let btn = document.createElement('div');
                    btn.className = 'chip-hora';
                    btn.innerText = h;
                    btn.onclick = function() {
                        document.querySelectorAll('.chip-hora').forEach(c => c.classList.remove('active'));
                        this.classList.add('active');
                        selHora = h;
                    };
                    div.appendChild(btn);
                });
            } else {
                div.innerHTML = '<p class="text-danger small fw-bold">Sin citas disponibles para esta fecha.</p>';
            }
        })
        .catch(err => {
            console.error(err);
            alert("No se pudieron cargar los horarios.");
        });
    });

    // 4. FUNCIÓN AGENDAR (REPARADO)
    function agendarP2() {
        let tel = document.getElementById('p2-tel').value;
        let staff = document.getElementById('p2-staff').value;
        let fecha = document.getElementById('p2-fecha').value;

        // Validaciones críticas
        if(!servicioSeleccionado) return alert("¡Padrino, selecciona un servicio primero!");
        if(!fecha) return alert("Falta la fecha.");
        if(!selHora) return alert("Elige un horario.");
        if(tel.length < 10) return alert("Escribe un teléfono válido (10 dígitos).");

        let fd = new FormData();
        fd.append('id_empresa', '@Model.id_empresa');
        fd.append('fecha', fecha);
        fd.append('hora', selHora);
        fd.append('tipo_servicio', servicioSeleccionado);
        fd.append('quien_atiende', staff);
        
        // Bloquear botón para evitar doble registro (como pidió Karla)
        const btn = event.target;
        btn.disabled = true;
        btn.innerText = "Procesando...";

        fetch('/Home/AgendarCita', { method: 'POST', body: fd })
        .then(r => r.json())
        .then(d => {
            if(d.success) {
                alert("¡Cita agendada con éxito!");
                window.location.href = '/mi-perfil';
            } else {
                alert("Error: " + (d.mensaje || "No se pudo agendar."));
                btn.disabled = false;
                btn.innerText = "CONFIRMAR CITA";
            }
        })
        .catch(e => {
            alert("Error de conexión con el servidor.");
            btn.disabled = false;
            btn.innerText = "CONFIRMAR CITA";
        });
    }
</script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
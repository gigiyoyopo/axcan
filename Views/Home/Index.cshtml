@model IEnumerable<axcan.Models.Empresa>
@{
    ViewData["Title"] = "Gestión de Citas";
}

<header class="hero-section py-5 text-center">
    <div class="container py-5">
        <h1 class="display-4 fw-bold mb-3 hero-title">
            Encuentra y agenda tu <span>próxima cita</span>
        </h1>
        <p class="lead text-muted mb-5">
            La plataforma que conecta tus servicios locales favoritos con tu agenda, en tiempo real.
        </p>
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden border">
                    <span class="input-group-text bg-white border-0 ps-4">🔍</span>
                    <input type="text" class="form-control border-0" placeholder="¿Qué servicio buscas?">
                    <button class="btn btn-primary px-5 fw-bold">Buscar</button>
                </div>
            </div>
        </div>
    </div>
</header>

<div id="carruselBanners" class="carousel slide carousel-fade container mb-5" data-bs-ride="carousel">
    <div class="carousel-inner shadow-sm rounded-4">
        <div class="carousel-item active"><img src="~/imagenesaxcan/prueba1.jpg" class="d-block w-100 banner-img"></div>
        <div class="carousel-item"><img src="~/imagenesaxcan/prueba2.jpg" class="d-block w-100 banner-img"></div>
        <div class="carousel-item"><img src="~/imagenesaxcan/prueba3.jpg" class="d-block w-100 banner-img"></div>
    </div>
</div>

<section class="py-5 bg-light">
    <div class="container">
        <h3 class="fw-bold mb-4 text-center">Negocios destacados en tu zona</h3>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var empresa in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 card-negocio">
                            <img src="@(string.IsNullOrEmpty(empresa.logotipo_url) ? "/imagenesaxcan/prueba1.jpg" : empresa.logotipo_url)" class="card-img-top banner-card rounded-top" alt="Negocio">
                            <div class="card-body">
                                <span class="badge bg-primary mb-2">@empresa.rubro</span>
                                <h5 class="card-title fw-bold">@empresa.nombre_empresa</h5>
                                <p class="text-muted small"><i class="bi bi-geo-alt"></i> Ubicado en el Mapa</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <button class="btn btn-outline-dark btn-sm rounded-pill">Agendar</button>
                                    <span class="text-warning fw-bold small"><i class="bi bi-star-fill"></i> 4.8</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">No hay negocios registrados todavía.</p>
                </div>
            }
        </div>
    </div>
</section>

            }
        </div>
    </div>
</section>


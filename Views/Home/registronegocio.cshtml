@model axcan.Models.Empresa
@{
    Layout = "_Layout"; // Quitamos el null para que se vea el menú pro
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            
            <header class="mb-4 text-center">
                <h1 class="fw-bold"><i class="bi bi-shop text-primary"></i> Da de alta tu negocio</h1>
                <p class="text-muted">Completa la información para activar tu panel de administración.</p>
            </header>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <div class="card shadow-lg border-0 p-4" style="border-radius: 20px;">
                <form asp-controller="Home" asp-action="GuardarEmpresa" method="POST" enctype="multipart/form-data">
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Nombre del Negocio</label>
                            <input type="text" name="nombre_empresa" class="form-control" placeholder="Ej. Tacos El Iguano" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Rubro / Categoría</label>
                            <select name="rubro" class="form-select" required>
                                <option value="Comida">🍴 Comida / Restaurante</option>
                                <option value="Barberia">💈 Barbería / Estética</option>
                                <option value="Consultorio">🩺 Consultorio Médico</option>
                                <option value="Tienda">🛒 Tienda / Abarrotes</option>
                                <option value="Otros">✨ Otros</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Ubicación en el Mapa</label>
                            <div class="alert alert-info py-2 small">
                                <i class="bi bi-info-circle"></i> Busca tu dirección o usa el botón de <b>GPS</b> para precisión total.
                            </div>
                            
                            <div id="mapaRegistro" style="height: 400px; border-radius: 15px;" class="border shadow-sm"></div>

                            <div class="d-flex gap-2 mt-2">
                                <input type="text" id="buscadorUbi" class="form-control" placeholder="Escribe calle, número y ciudad...">
                                <button type="button" id="btnBuscar" class="btn btn-dark">🔍 Buscar</button>
                                <button type="button" class="btn btn-info text-white fw-bold" onclick="miUbicacionReal()">
                                    <i class="bi bi-geo-alt-fill"></i> GPS
                                </button>
                            </div>

                            <input type="hidden" id="latitud" name="ubicacion_lat">
                            <input type="hidden" id="longitud" name="ubicacion_lng">
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-3">
                        <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold shadow">
                            <i class="bi bi-check-circle"></i> Finalizar Registro
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancelar</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        // Inicializar Mapa (Ubicación por defecto: México)
        var map = L.map('mapaRegistro').setView([19.4326, -99.1332], 13);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        var marker = L.marker([19.4326, -99.1332], { draggable: true }).addTo(map);

        // Al mover el pin manualmente
        marker.on('dragend', function (e) {
            updateCoords(e.target.getLatLng().lat, e.target.getLatLng().lng);
        });

        function updateCoords(lat, lng) {
            document.getElementById('latitud').value = lat;
            document.getElementById('longitud').value = lng;
        }

        // --- BOTÓN GPS TIEMPO REAL ---
        function miUbicacionReal() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(function (position) {
                    var lat = position.coords.latitude;
                    var lng = position.coords.longitude;
                    map.setView([lat, lng], 18);
                    marker.setLatLng([lat, lng]);
                    updateCoords(lat, lng);
                }, function() {
                    alert("No se pudo obtener la ubicación GPS.");
                });
            }
        }

        // --- BUSCADOR POR TEXTO (Nominatim API) ---
        document.getElementById('btnBuscar').addEventListener('click', function() {
            var query = document.getElementById('buscadorUbi').value;
            if(query.length < 3) return;

            fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${query}`)
                .then(response => response.json())
                .then(data => {
                    if(data.length > 0) {
                        var lat = data[0].lat;
                        var lon = data[0].lon;
                        map.setView([lat, lon], 16);
                        marker.setLatLng([lat, lon]);
                        updateCoords(lat, lon);
                    } else {
                        alert("No encontramos esa dirección, padrino.");
                    }
                });
        });

        // Click en el mapa para mover pin
        map.on('click', function(e) {
            marker.setLatLng(e.latlng);
            updateCoords(e.latlng.lat, e.latlng.lng);
        });

        // Cargar coordenadas iniciales
        updateCoords(19.4326, -99.1332);
    </script>
}
@model axcan.Models.Empresa
@{
    Layout = null; // O "_Layout" si quieres mantener el menú general
    var citas = ViewBag.Citas as List<axcan.Models.Cita>;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>AXCAN - Panel de @Model.nombre_empresa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --gold-axcan: #D4AF37; --dark-axcan: #111; }
        body { background-color: #f4f6f9; }
        .sidebar { background-color: var(--dark-axcan); min-height: 100vh; color: white; }
        .hora-badge { background: var(--gold-axcan); color: black; font-weight: bold; padding: 5px 15px; border-radius: 10px; min-width: 100px; text-align: center; }
        .cita-card { border-radius: 15px; border: none; margin-bottom: 15px; transition: 0.3s; }
        .cita-card:hover { transform: scale(1.01); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
    </style>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <div class="col-md-3 col-lg-2 sidebar p-4 d-none d-md-block">
            <h4 class="text-center mb-4" style="color:var(--gold-axcan)">AXCAN</h4>
            <div class="text-center mb-4">
                <img src="@Model.logotipo_url" width="80" class="rounded-circle border border-2 border-warning">
                <p class="mt-2 small">@Model.nombre_empresa</p>
            </div>
            <nav class="nav flex-column">
                <a class="nav-link text-white active" href="#"><i class="bi bi-calendar3 me-2"></i> Agenda</a>
                <a class="nav-link text-light" href="/"><i class="bi bi-house me-2"></i> Inicio</a>
                <a class="nav-link text-danger mt-5" href="/Home/Logout"><i class="bi bi-box-arrow-left me-2"></i> Salir</a>
            </nav>
        </div>

        <div class="col-md-9 col-lg-10 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Agenda de Hoy</h2>
                <span class="badge bg-dark p-2">@DateTime.Now.ToString("dd MMMM, yyyy")</span>
            </div>

            <div class="row">
                @if (citas != null && citas.Any())
                {
                    foreach (var cita in citas)
                    {
                        <div class="col-12 col-xl-6">
                            <div class="card cita-card shadow-sm border-start border-4 @(cita.estatus == "pendiente" ? "border-warning" : "border-success")">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <div class="hora-badge me-4">@cita.hora</div>
                                        <div>
                                            <h5 class="fw-bold mb-1">@cita.tipo_servicio</h5>
                                            <p class="mb-0 text-muted small">
                                                <i class="bi bi-person"></i> Atiende: @cita.quien_atiende
                                            </p>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge @(cita.estatus == "pendiente" ? "bg-warning text-dark" : "bg-success") mb-2 px-3 py-2">
                                            @cita.estatus.ToUpper()
                                        </span>
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-dark dropdown-toggle" data-bs-toggle="dropdown">Acciones</button>
                                            <ul class="dropdown-menu">
                                                <li><a class="dropdown-item" href="#" onclick="cambiarEstatus(@cita.id_cita, 'completada')">Marcar Completada</a></li>
                                                <li><a class="dropdown-item text-danger" href="#" onclick="cambiarEstatus(@cita.id_cita, 'cancelada')">Cancelar</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-calendar-x display-1 text-muted"></i>
                        <p class="mt-3 text-muted">No hay citas registradas para esta empresa.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function cambiarEstatus(id, nuevoEstado) {
        if(!confirm("¿Deseas cambiar el estado de esta cita?")) return;
        
        let fd = new FormData();
        fd.append("id_cita", id);
        fd.append("nuevoEstado", nuevoEstado);

        fetch('/Home/ActualizarEstatusCita', { method: 'POST', body: fd })
        .then(r => r.json()).then(d => {
            if(d.success) location.reload();
            else alert("Error al actualizar");
        });
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
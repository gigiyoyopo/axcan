@model axcan.Models.Usuario
@{
    ViewData["Title"] = "Configuración de Cuenta"; 
}

<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-dark text-white p-4 rounded-top-4">
            <div class="d-flex align-items-center">
                <i class="bi bi-person-gear fs-1 me-3 text-primary"></i> [cite: 156]
                <div>
                    <h3 class="mb-0">Mi Perfil</h3>
                    <p class="mb-0 opacity-75">Gestiona tu información personal</p>
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-success">@TempData["Mensaje"]</div> 
            }

            @* El secreto es el FORM y los INPUTS *@
            <form asp-action="ActualizarPerfil" method="post">
                <div class="row g-4">
                    
                    @* Estatus (Solo lectura) *@
                    <div class="col-12">
                        <div class="p-3 rounded-3 @(Model.rol == "administrador" ? "bg-info-subtle border border-info" : "bg-light border")"> [cite: 160, 161]
                            <h6 class="text-uppercase fw-bold small mb-1">Rol Actual</h6>
                            <h4 class="mb-0 text-capitalize">@Model.rol</h4> [cite: 163]
                        </div>
                    </div>

                    @* Inputs editables coincidiendo con el Modelo Usuario *@
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Nombre</label>
                        <input type="text" asp-for="nombre" class="form-control" required> [cite: 40]
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Ap. Paterno</label>
                        <input type="text" asp-for="apellido_paterno" class="form-control" required> [cite: 41]
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Ap. Materno</label>
                        <input type="text" asp-for="apellido_materno" class="form-control" required> [cite: 41]
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Correo</label>
                        <input type="email" asp-for="correo" class="form-control" required> [cite: 39]
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nueva Contraseña</label>
                        <input type="password" name="password" class="form-control" placeholder="Dejar vacío si no cambia">
                    </div>
                </div>

                <div class="mt-5 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Guardar Cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a> [cite: 173]
                </div>
            </form>
        </div>
    </div>
</div>
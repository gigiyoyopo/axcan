@model axcan.Models.Usuario
@{
    ViewData["Title"] = "Configuración de Cuenta";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-dark text-white p-4 rounded-top-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-person-gear fs-1 me-3 text-primary"></i>
                        <div>
                            <h3 class="mb-0">Mi Perfil</h3>
                            <p class="mb-0 opacity-75">Gestiona la información de tu cuenta en AXCAN</p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Mensaje"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="row g-4">
                        <div class="col-12">
                            <div class="p-3 rounded-3 @(Model.rol == "administrador" ? "bg-info-subtle border border-info" : "bg-light border")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="text-uppercase fw-bold small mb-1">Estatus de la Cuenta</h6>
                                        <h4 class="mb-0 text-capitalize">
                                            <i class="bi @(Model.rol == "administrador" ? "bi-patch-check-fill text-info" : "bi-person text-secondary")"></i> 
                                            @Model.rol
                                        </h4>
                                    </div>
                                    @if (Model.rol == "usuario")
                                    {
                                        <a asp-action="registronegocio" class="btn btn-warning btn-sm fw-bold">
                                            🚀 ¡Ascender a Admin!
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">Nombre Completo</label>
                            <p class="fs-5 border-bottom pb-2">@Model.nombre @Model.apellido_paterno @Model.apellido_materno</p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">Nombre de Usuario</label>
                            <p class="fs-5 border-bottom pb-2">@@@Model.username</p>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold text-muted small">Correo Electrónico</label>
                            <p class="fs-5 border-bottom pb-2">@Model.correo</p>
                        </div>

                        <div class="col-md-6 text-muted small">
                            <i class="bi bi-calendar-event me-1"></i> Miembro desde: @Model.fecha_registro?.ToString("dd/MM/yyyy")
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-2">
                        <button class="btn btn-primary" onclick="window.print()">
                            <i class="bi bi-printer me-1"></i> Imprimir Comprobante
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary text-dark">Volver</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
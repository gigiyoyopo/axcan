@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro Exitoso - AXCAN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/estilo.css">
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100 py-4" style="background-image: url('/imagenesaxcan/fondo_login_registro.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat; background-attachment: fixed; position: relative; z-index: 1;">

    <div class="container d-flex justify-content-center">
        <div class="card shadow-lg p-5 auth-card col-12 col-sm-8 col-md-6 col-lg-5 text-center">
            
            <div class="mb-4">
                <i class="bi bi-check-circle-fill" style="font-size: 5rem; color: #28a745;"></i>
            </div>

            <h2 class="fw-bold mb-3 text-dark">¡Registro Exitoso!</h2>
            
            <p class="text-muted mb-4 fs-5">
                Bienvenido a AXCAN. Tu cuenta ha sido creada correctamente y ya eres parte de la plataforma.
            </p>

            <hr class="mb-4">

            <a asp-controller="Home" asp-action="login" class="btn btn-primary btn-lg w-100 fw-bold shadow">
                <i class="bi bi-box-arrow-in-right me-2"></i> AHORA INICIA SESIÓN
            </a>

        </div>
    </div>

</body>
</html>
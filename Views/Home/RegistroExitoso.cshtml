@{
    Layout = "_Layout"; // O el layout que uses para que no se vea pelona la página
}

<div class="container mt-5 text-center">
    <div class="card shadow-lg p-5 border-0 rounded-4">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        </div>
        <h1 class="fw-bold text-dark">¡Registro Completado!</h1>
        <p class="lead text-muted">@TempData["Exito"]</p>
        <hr class="my-4" style="width: 50%; margin: auto;">
        <p>Ya puedes acceder a todas las funciones de **AXCAN**.</p>
        <div class="mt-4">
            <a href="@Url.Action("login")" class="btn btn-warning btn-lg fw-bold px-5 rounded-pill shadow">
                Iniciar Sesión Ahora
            </a>
        </div>
    </div>
</div>